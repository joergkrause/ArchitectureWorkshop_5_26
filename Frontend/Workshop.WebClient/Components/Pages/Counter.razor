@page "/counter"
@using Workshop.ServiceClients

@inject RestClient RestClient

<PageTitle>Customer</PageTitle>

<h1>Customer</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="GetCustomers">Click me</button>

@foreach (var customer in customerDtos)
{
  <p>@customer.CustomerName</p>
}


@code {
  private int currentCount = 0;
  private IEnumerable<CustomerDto> customerDtos = [];

  private async Task GetCustomers()
  {
    customerDtos = await RestClient.GetAllAsync();
    currentCount = customerDtos.Count();
  }

}
